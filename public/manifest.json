{
  "manifest_version": 3,
  "name": "AI Bookmark Organizer",
  "short_name": "Bookmark AI",
  "version": "0.1.1",
  "description": "Preview and organize Chrome bookmarks into an AI-managed folder with provider fallbacks.",
  "minimum_chrome_version": "116",
  "permissions": ["bookmarks", "storage", "sidePanel"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "AI Bookmark Organizer"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
